---
import '../styles/global.css';

interface Props {
	title?: string;
	description?: string;
}

const {
	title = 'nutmeg — Football data analytics for AI coding tools',
	description = 'A Claude Code plugin and MCP server for football data. Makes your AI agent an expert at Opta, StatsBomb, Wyscout, SportMonks, and more.',
} = Astro.props;
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<title>{title}</title>
		<meta name="description" content={description} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:type" content="website" />
		<meta property="og:url" content="https://nutmeg.withqwerty.com" />
		<meta name="twitter:card" content="summary_large_image" />
		<link rel="icon" type="image/png" href="/nutmeg/favicon.png" />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;700;900&family=IBM+Plex+Mono:wght@400;500;600&display=swap" rel="stylesheet" />
	</head>
	<body>
		<slot />
	</body>
</html>
