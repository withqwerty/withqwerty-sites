<script>
var toolChoice = null;
var goalChoice = null;
document.querySelectorAll('.q-btn').forEach(function(btn) {
  btn.addEventListener('click', function() {
    var group = btn.dataset.group;
    var value = btn.dataset.value;
    var isGoal = group === 'goal';
    document.querySelectorAll('.q-btn[data-group="' + group + '"]').forEach(function(b) {
      b.classList.remove('active', 'active-blue');
    });
    btn.classList.add(isGoal ? 'active-blue' : 'active');
    if (group === 'tool') toolChoice = value;
    if (group === 'goal') goalChoice = value;
    document.querySelectorAll('.q-result').forEach(function(r) { r.hidden = true; });
    if (!toolChoice || !goalChoice) return;
    if (goalChoice === 'explore' && toolChoice !== 'claude-code') {
      document.getElementById('result-generic-explore').hidden = false;
      return;
    }
    var id = 'result-' + toolChoice + '-' + goalChoice;
    var el = document.getElementById(id);
    if (el) el.hidden = false;
  });
});
document.querySelectorAll('.q-copy-btn').forEach(function(btn) {
  btn.addEventListener('click', function() {
    navigator.clipboard.writeText(btn.dataset.cmd);
    btn.classList.add('copied');
    setTimeout(function() { btn.classList.remove('copied'); }, 1500);
  });
});
</script>
