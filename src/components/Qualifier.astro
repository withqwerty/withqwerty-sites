---
// Interactive "get started" qualifier — shows tailored install instructions
// based on user's AI tool and desired scope.
//
// All HTML is rendered via set:html to avoid Astro treating JSON config
// strings (with curly braces) as template expressions.
---

<Fragment set:html={`
<style>
.qualifier { background: #fff; border: 2px solid #e5e5e5; border-radius: 16px; padding: 1.5rem 1.75rem; margin-bottom: 2.5rem; }
.qualifier h2 { font-size: 1.3rem; font-weight: 900; margin-bottom: 0.25rem; }
.qualifier > p { color: #666; font-size: 0.95rem; margin-bottom: 1.25rem; }
.q-group { margin-bottom: 1rem; }
.q-label { font-size: 0.85rem; font-weight: 700; margin-bottom: 0.5rem; }
.q-options { display: flex; gap: 0.5rem; flex-wrap: wrap; }
.q-btn { font-family: 'DM Sans', -apple-system, sans-serif; font-size: 0.85rem; font-weight: 500; padding: 0.4rem 1rem; border: 2px solid #e5e5e5; border-radius: 8px; background: #FAFAFA; color: #1a1a1a; cursor: pointer; transition: all 0.12s ease; }
.q-btn:hover { border-color: #2D6A4F; }
.q-btn.active { background: #2D6A4F; border-color: #2D6A4F; color: white; }
.q-btn.active-blue { background: #1565C0; border-color: #1565C0; color: white; }
.q-result { margin-top: 1.25rem; padding-top: 1.25rem; border-top: 1px solid #e5e5e5; }
.q-result[hidden] { display: none; }
.q-result-title { font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: #2D6A4F; margin-bottom: 0.75rem; }
.q-step { margin-bottom: 1.25rem; }
.q-step-head { display: flex; align-items: center; gap: 0.4rem; margin-bottom: 0.3rem; }
.q-step-num { display: inline-flex; align-items: center; justify-content: center; width: 1.4rem; height: 1.4rem; border-radius: 50%; background: #2D6A4F; color: white; font-size: 0.7rem; font-weight: 700; flex-shrink: 0; }
.q-step-num.blue { background: #1565C0; }
.q-step-label { font-size: 0.9rem; font-weight: 500; }
.q-code-row { display: flex; align-items: center; gap: 0.5rem; background: #f5f5f5; border: 1px solid #e5e5e5; border-radius: 8px; padding: 0.5rem 0.75rem; margin-top: 0.35rem; margin-left: 1.8rem; }
.q-code-row code { font-family: 'IBM Plex Mono', 'SF Mono', monospace; font-size: 0.8rem; color: #1a1a1a; background: none; padding: 0; flex: 1; white-space: nowrap; overflow-x: auto; }
.q-copy-btn { background: none; border: none; color: #999; cursor: pointer; padding: 0.2rem; border-radius: 4px; display: flex; align-items: center; flex-shrink: 0; transition: color 0.15s; }
.q-copy-btn:hover { color: #1a1a1a; }
.q-copy-btn .check { display: none; }
.q-copy-btn.copied .copy { display: none; }
.q-copy-btn.copied .check { display: block; color: #2D6A4F; }
.q-step p { font-size: 0.85rem; color: #666; margin-top: 0.25rem; padding-left: 1.8rem; }
.q-note { font-size: 0.85rem; color: #666; margin-top: 0.75rem; padding: 0.6rem 0.8rem; background: #FAFAFA; border-radius: 8px; }
</style>

