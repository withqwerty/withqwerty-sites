---
interface Props {
	links: Array<{ href: string; label: string }>;
	credit?: string;
}

const { links, credit } = Astro.props;
---

<div class="footer">
	<p>
		{links.map(({ href, label }, i) => (
			<>{i > 0 && ' · '}<a href={href}>{label}</a></>
		))}
		{' · '}<a href="https://x.com/withqwerty" class="x-link" aria-label="X (Twitter)"><svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg></a>
		{credit && <>{' · '}Made by <a href="https://www.withqwerty.com">withqwerty</a></>}
	</p>
</div>

<style>
	.footer {
		margin-top: 2.5rem;
		padding-top: 1.5rem;
		border-top: 1px solid var(--border);
		color: var(--fg-muted);
		font-size: 0.85rem;
	}

	.footer a { text-decoration: underline; text-underline-offset: 2px; }
	.footer .x-link { text-decoration: none; vertical-align: middle; }
</style>
