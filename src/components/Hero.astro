---
interface Props {
	icon: string;
	title: string;
	tagline: string;
	pitch: string;
	badge?: string;
}

const { icon, title, tagline, pitch, badge } = Astro.props;
---

<div class="hero">
	<img src={icon} alt={title} class="hero-icon" />
	<div>
		<div class="hero-title-row">
			<h1>{title}</h1>
			{badge && <span class="badge">{badge}</span>}
		</div>
		<div class="tagline">{tagline}</div>
	</div>
</div>

<p class="pitch" set:html={pitch} />

<style>
	.hero {
		display: flex;
		align-items: center;
		gap: 2rem;
		margin-bottom: 2rem;
	}

	.hero-icon { width: 80px; height: 80px; flex-shrink: 0; }

	.hero-title-row {
		display: flex;
		align-items: center;
		gap: 0.75rem;
	}

	.hero h1 {
		font-size: 2.5rem;
		font-weight: 900;
		letter-spacing: -0.03em;
		line-height: 1.1;
	}

	.badge {
		display: inline-block;
		font-size: 0.65rem;
		font-weight: 800;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--green, #2d7a4f);
		border: 2px solid var(--green, #2d7a4f);
		border-radius: 6px;
		padding: 0.15rem 0.5rem;
		transform: rotate(-4deg);
		white-space: nowrap;
		line-height: 1.3;
	}

	.hero .tagline {
		color: var(--fg-muted);
		font-size: 1.1rem;
		margin-top: 0.25rem;
	}

	.pitch {
		font-size: 1.1rem;
		line-height: 1.7;
		max-width: 720px;
		margin-bottom: 2.5rem;
		color: var(--fg-muted);
	}
</style>
