---
interface Props {
	providers: Array<{ name: string; chunks: number }>;
}

const { providers } = Astro.props;
---

<div class="providers-grid">
	{providers.map(({ name, chunks }) => (
		<div class="provider-chip">
			<div class="provider-name">{name}</div>
			<div class="provider-chunks">{chunks} chunks</div>
		</div>
	))}
</div>

<style>
	.providers-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
		gap: 0.5rem;
		margin-bottom: 2rem;
	}

	.provider-chip {
		background: var(--card-bg);
		border: 2px solid var(--border);
		border-radius: 10px;
		padding: 0.6rem 0.8rem;
		text-align: center;
	}

	.provider-name { font-weight: 700; font-size: 0.9rem; }
	.provider-chunks { font-size: 0.75rem; color: var(--fg-muted); }
</style>
