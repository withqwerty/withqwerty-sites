---
interface Props {
	headline: string;
	description: string;
	code: string;
	color?: 'green' | 'blue';
}

const { headline, description, code, color = 'green' } = Astro.props;
---

<div class={`cta-banner ${color}`}>
	<h2>{headline}</h2>
	<p>{description}</p>
	<code>{code}</code>
</div>

<style>
	.cta-banner {
		border-radius: var(--radius);
		padding: 2rem;
		text-align: center;
		margin-top: 2rem;
		color: white;
	}

	.cta-banner.green { background: var(--green); }
	.cta-banner.blue { background: var(--blue); }

	.cta-banner h2 { font-size: 1.5rem; font-weight: 900; margin-bottom: 0.5rem; }
	.cta-banner p { opacity: 0.8; margin-bottom: 1rem; }
	.cta-banner code { background: rgba(255,255,255,0.15); color: white; font-size: 0.9rem; padding: 0.3rem 0.8rem; border-radius: 6px; }
</style>
