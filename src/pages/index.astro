---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import Qualifier from '../components/Qualifier.astro';
import SkillsGrid from '../components/SkillsGrid.astro';
import ProvidersTable from '../components/ProvidersTable.astro';
import StatsRow from '../components/StatsRow.astro';
import InstallRow from '../components/InstallRow.astro';
import ToolsGrid from '../components/ToolsGrid.astro';
import ExampleQueries from '../components/ExampleQueries.astro';
import ProvidersGrid from '../components/ProvidersGrid.astro';
import CtaBanner from '../components/CtaBanner.astro';
import Footer from '../components/Footer.astro';

const entrySkills = [
	{ name: '/nutmeg', desc: 'Describe what you want — it handles the rest' },
	{ name: '/nutmeg-learn', desc: 'Concepts, resources, provider docs' },
];

const subSkills = [
	{ name: '/nutmeg-acquire', desc: 'Fetch data and manage API keys' },
	{ name: '/nutmeg-wrangle', desc: 'Transform and reshape data' },
	{ name: '/nutmeg-compute', desc: 'Derived metrics (xG, PPDA...)' },
	{ name: '/nutmeg-analyse', desc: 'Explore and interpret data' },
	{ name: '/nutmeg-brainstorm', desc: 'Visualisation ideation' },
	{ name: '/nutmeg-review', desc: 'Check data code and charts' },
	{ name: '/nutmeg-store', desc: 'Storage and publishing' },
	{ name: '/nutmeg-heal', desc: 'Fix broken scrapers' },
];

const dataProviders = [
	{ name: 'StatsBomb', events: 'yes' as const, stats: 'yes' as const, xg: 'yes' as const, free: 'partial' as const, freeNote: 'Open data' },
	{ name: 'Opta', events: 'yes' as const, stats: 'yes' as const, xg: 'yes' as const, free: 'no' as const },
	{ name: 'Wyscout', events: 'yes' as const, stats: 'yes' as const, xg: 'no' as const, free: 'no' as const },
	{ name: 'SportMonks', events: 'partial' as const, stats: 'yes' as const, xg: 'no' as const, free: 'partial' as const, freeNote: 'Free tier' },
	{ name: 'FBref', events: 'no' as const, stats: 'yes' as const, xg: 'yes' as const, free: 'yes' as const },
	{ name: 'Understat', events: 'no' as const, stats: 'partial' as const, xg: 'yes' as const, free: 'yes' as const },
];

const mcpTools = [
	{ name: 'search_docs', desc: 'Full-text search across all providers' },
	{ name: 'list_providers', desc: 'See all indexed providers' },
	{ name: 'compare_providers', desc: 'Compare how providers handle concepts' },
	{ name: 'request_update', desc: 'Flag outdated docs or request new ones' },
];

const exampleQueries = [
	'"What is Opta qualifier 76?"',
	'"How does StatsBomb represent shots?"',
	'"Compare Opta and Wyscout coordinates"',
	'"Does SportMonks have xG?"',
	'"How does SPADL represent a tackle?"',
];

const indexedProviders = [
	{ name: 'StatsBomb', chunks: 143 },
	{ name: 'kloppy', chunks: 100 },
	{ name: 'SportMonks', chunks: 71 },
	{ name: 'databallpy', chunks: 63 },
	{ name: 'mplsoccer', chunks: 62 },
	{ name: 'Wyscout', chunks: 61 },
	{ name: 'Free sources', chunks: 45 },
	{ name: 'soccerdata', chunks: 40 },
	{ name: 'Opta', chunks: 29 },
	{ name: 'socceraction', chunks: 26 },
];

const footerLinks = [
	{ href: 'https://github.com/withqwerty/nutmeg', label: 'nutmeg on GitHub' },
	{ href: 'https://github.com/withqwerty/football-docs', label: 'football-docs on GitHub' },
	{ href: 'https://www.npmjs.com/package/football-docs', label: 'football-docs on npm' },
	{ href: '#', label: 'MIT License' },
];
---

<BaseLayout>
	<Nav links={[
		{ href: '#get-started', label: 'Get started' },
		{ href: '#nutmeg', label: 'nutmeg' },
		{ href: '#football-docs', label: 'football-docs' },
		{ href: 'https://github.com/withqwerty/nutmeg', label: 'GitHub', external: true },
	]} />

	<!-- nutmeg -->
	<section id="nutmeg">
		<Hero
			icon="/nutmeg/icon.svg"
			title="nutmeg"
			tagline="Football data analytics for AI coding tools"
			badge="IN BETA!"
			pitch="Makes your AI agent an expert at football data. It looks up the real docs instead of guessing &mdash; qualifier IDs, coordinate systems, API endpoints, method signatures. All verified, all sourced."
		/>

		<Qualifier />

		<div class="section-title green">Start here</div>
		<SkillsGrid skills={entrySkills} variant="entry" />

		<div class="section-title green muted">Sub-skills <span class="section-subtitle">auto-dispatched or called directly</span></div>
		<SkillsGrid skills={subSkills} />

		<div class="section-title green">Providers</div>
		<ProvidersTable providers={dataProviders} />
	</section>

	<hr class="product-divider" />

	<!-- football-docs -->
	<section id="football-docs">
		<Hero
			icon="/football-docs/icon.svg"
			title="football-docs"
			tagline="Like Context7 for football data"
			badge="IN BETA!"
			pitch="Searchable documentation for 16 football data providers, built for AI coding agents. Your agent looks up the real docs instead of guessing from training data. Works with any tool that supports MCP."
		/>

		<StatsRow stats={[
			{ value: 640, label: 'searchable chunks' },
			{ value: 16, label: 'providers' },
			{ value: 4, label: 'MCP tools' },
		]} />

		<div class="section-title blue">Install</div>
		<InstallRow cards={[
			{ label: 'Claude Code', code: 'claude mcp add football-docs -- npx -y football-docs', color: 'blue' },
			{ label: 'Any MCP client', code: 'npx -y football-docs', color: 'blue' },
		]} />

		<div class="section-title blue">Tools</div>
		<ToolsGrid tools={mcpTools} />

		<div class="section-title blue">Example queries</div>
		<ExampleQueries queries={exampleQueries} />

		<div class="section-title blue">Indexed providers</div>
		<ProvidersGrid providers={indexedProviders} />
	</section>

	<CtaBanner
		headline="Start building with football data"
		description="Install in 30 seconds. Your AI agent becomes a football data expert."
		code="/plugin marketplace add withqwerty/plugins"
		code2="/plugin install nutmeg@withqwerty"
	/>

	<Footer
		links={footerLinks}
		credit="Made by withqwerty"
	/>
</BaseLayout>
